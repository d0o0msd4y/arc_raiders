<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ARC Raiders – Blueprint Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #0b0c10;
    --panel:     #0e1018;
    --panel2:    #12151e;
    --panel3:    #161a25;
    --border:    #1d2235;
    --border2:   #2a3350;
    --cyan:      #00cfff;
    --orange:    #ff6b35;
    --green:     #5eff3a;
    --gold:      #ffcc44;
    --purple:    #b06aff;
    --red:       #ff3355;
    --grey:      #556070;
    --text:      #b0c4de;
    --text2:     #6a80a0;
    --white:     #ddeeff;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body { height: 100%; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    overflow: hidden;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Faint grid overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      repeating-linear-gradient(0deg,  transparent, transparent 39px, rgba(0,207,255,0.022) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,207,255,0.022) 40px);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Chrome bar at top ── */
  .topbar {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0;
    height: 44px;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .topbar-back {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 18px;
    height: 100%;
    border-right: 1px solid var(--border);
    color: var(--text2);
    text-decoration: none;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 0.15s, background 0.15s;
  }
  .topbar-back:hover { color: var(--cyan); background: rgba(0,207,255,0.05); }

  .topbar-crumb {
    display: flex;
    align-items: center;
    gap: 0;
    height: 100%;
    padding-left: 18px;
  }

  .crumb {
    font-family: 'Orbitron', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text2);
  }

  .crumb-sep { margin: 0 8px; color: var(--border2); font-size: 0.8rem; }
  .crumb.active { color: var(--white); }

  .topbar-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0;
    height: 100%;
  }

  .topbar-prog {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 18px;
    border-left: 1px solid var(--border);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text2);
    white-space: nowrap;
  }

  .topbar-prog strong { color: var(--cyan); font-weight: 400; }

  .tp-bar-bg { width: 80px; height: 3px; background: var(--panel3); border: 1px solid var(--border); overflow: hidden; }
  .tp-bar-fill { height: 100%; background: linear-gradient(90deg, var(--cyan), var(--green)); box-shadow: 0 0 5px rgba(0,207,255,0.6); transition: width 0.35s ease; }

  /* ── Body layout ── */
  .body-wrap {
    flex: 1;
    display: flex;
    min-height: 0;
    position: relative;
    z-index: 1;
  }

  /* ── Left sidebar ── */
  .sidebar {
    width: 196px;
    flex-shrink: 0;
    background: var(--panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .sidebar::-webkit-scrollbar { display: none; }

  .sb-section {
    padding: 10px 0 4px;
  }

  .sb-heading {
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text2);
    padding: 0 14px 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .sb-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .sb-btn {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 7px 14px;
    background: none;
    border: none;
    border-left: 2px solid transparent;
    color: var(--text2);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.1s;
    text-align: left;
    gap: 8px;
  }

  .sb-btn:hover { color: var(--text); background: rgba(255,255,255,0.03); }

  .sb-btn.active {
    color: var(--cyan);
    border-left-color: var(--cyan);
    background: rgba(0,207,255,0.07);
  }

  .sb-btn .dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .sb-btn .sb-count {
    margin-left: auto;
    font-size: 0.6rem;
    color: var(--text2);
    background: var(--panel2);
    border: 1px solid var(--border);
    padding: 0 5px;
    min-width: 22px;
    text-align: center;
  }

  .sb-btn.active .sb-count { color: var(--cyan); border-color: rgba(0,207,255,0.3); }

  .sb-divider { height: 1px; background: var(--border); margin: 4px 14px; }

  /* ── Main area ── */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* Search + count bar */
  .filterbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--panel2);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .search-wrap { position: relative; flex: 1; }
  .search-icon { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); color: var(--text2); font-size: 0.75rem; pointer-events: none; }

  .searchbox {
    width: 100%;
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 6px 10px 6px 28px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    outline: none;
    transition: border-color 0.15s;
  }
  .searchbox:focus { border-color: var(--cyan); }
  .searchbox::placeholder { color: var(--text2); }

  .result-count {
    font-size: 0.62rem;
    color: var(--text2);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  /* Grid scroll */
  .grid-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    scrollbar-width: thin;
    scrollbar-color: var(--border2) transparent;
  }
  .grid-scroll::-webkit-scrollbar { width: 4px; }
  .grid-scroll::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

  /* ── Blueprint grid ── */
  .bp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 6px;
  }

  /* ── Blueprint card ── */
  .bp-card {
    position: relative;
    background: var(--panel);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    display: flex;
    flex-direction: column;
  }

  /* Type accent — left edge stripe */
  .bp-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    z-index: 1;
  }

  .bp-card[data-type="Weapon"]::before    { background: var(--orange); }
  .bp-card[data-type="Grenade"]::before   { background: var(--gold); }
  .bp-card[data-type="Mine"]::before      { background: var(--red); }
  .bp-card[data-type="Augment"]::before   { background: var(--purple); }
  .bp-card[data-type="Mod"]::before       { background: var(--cyan); }
  .bp-card[data-type="Quick Use"]::before { background: var(--green); }
  .bp-card[data-type="Material"]::before  { background: var(--grey); }
  .bp-card[data-type="Ammo"]::before      { background: var(--grey); }
  .bp-card[data-type="???"]::before       { background: var(--border2); }

  /* Top-right corner notch */
  .bp-card::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 9px; height: 9px;
    background: var(--bg);
    clip-path: polygon(100% 0, 0 0, 100% 100%);
    z-index: 1;
  }

  .bp-card:hover {
    border-color: rgba(0,207,255,0.5);
    transform: translateY(-2px);
    box-shadow: 0 4px 18px rgba(0,207,255,0.1);
    z-index: 2;
  }

  /* Collected state */
  .bp-card.collected {
    border-color: rgba(94,255,58,0.35);
    background: rgba(94,255,58,0.03);
  }
  .bp-card.collected:hover {
    border-color: var(--green);
    box-shadow: 0 4px 18px rgba(94,255,58,0.12);
  }

  /* Image box — blueprint frame + icon layered */
  .bp-img {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: linear-gradient(150deg, #0c0f17 0%, #10141e 100%);
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Blueprint background frame (the papery worn look from the wiki) */
  .bp-frame {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    opacity: 0.9;
    /* Slight blue tint to the frame to match in-game look */
    filter: hue-rotate(10deg) saturate(0.8);
  }

  /* Fallback when no frame image */
  .bp-img.no-frame {
    background:
      linear-gradient(150deg, #0e1320 0%, #141a2a 100%);
    border-bottom: 1px solid var(--border);
  }

  /* The actual item icon on top of the frame */
  .bp-icon {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    padding: 12px;
    transition: opacity 0.18s, transform 0.18s;
  }

  .bp-card:hover .bp-icon { transform: scale(1.07); }

  /* Green tick when collected */
  .bp-tick {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(8,10,14,0.65);
    color: var(--green);
    font-size: 1.6rem;
    text-shadow: 0 0 12px var(--green);
    opacity: 0;
    transition: opacity 0.18s;
  }

  .bp-card.collected .bp-tick  { opacity: 1; }
  .bp-card.collected .bp-icon  { opacity: 0.25; }

  /* Unknown blueprint — question mark */
  .bp-unknown {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--border2);
    letter-spacing: 0;
  }

  /* Label strip below image */
  .bp-label {
    padding: 5px 7px 7px;
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,0.2);
  }

  .bp-name {
    display: block;
    font-size: 0.57rem;
    color: var(--text);
    letter-spacing: 0.03em;
    line-height: 1.3;
    text-align: center;
    word-break: break-word;
    margin-bottom: 3px;
    transition: color 0.15s;
  }

  .bp-card.collected .bp-name { color: var(--green); }
  .bp-card[data-type="???"]   .bp-name { color: var(--border2); }

  .bp-type {
    display: block;
    font-size: 0.48rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
  }

  .bp-card[data-type="Weapon"]    .bp-type { color: var(--orange); }
  .bp-card[data-type="Grenade"]   .bp-type { color: var(--gold); }
  .bp-card[data-type="Mine"]      .bp-type { color: var(--red); }
  .bp-card[data-type="Augment"]   .bp-type { color: var(--purple); }
  .bp-card[data-type="Mod"]       .bp-type { color: var(--cyan); }
  .bp-card[data-type="Quick Use"] .bp-type { color: var(--green); }
  .bp-card[data-type="Material"]  .bp-type { color: var(--grey); }
  .bp-card[data-type="Ammo"]      .bp-type { color: var(--grey); }
  .bp-card[data-type="???"]       .bp-type { color: var(--border2); }

  .no-results {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: var(--text2);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
  }

  /* ── Detail panel (slides in from right) ── */
  .backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 50;
    backdrop-filter: blur(2px);
  }
  .backdrop.open { display: block; }

  .detail {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 300px;
    background: var(--panel);
    border-left: 1px solid var(--border2);
    z-index: 51;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.22s cubic-bezier(.4,0,.2,1);
    box-shadow: -8px 0 48px rgba(0,0,0,0.7);
  }

  .detail.open { transform: translateX(0); }

  .detail-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .detail-head-label {
    font-size: 0.58rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text2);
  }

  .detail-close {
    background: none;
    border: none;
    color: var(--text2);
    font-size: 1rem;
    cursor: pointer;
    line-height: 1;
    padding: 2px 4px;
    font-family: 'Share Tech Mono', monospace;
    transition: color 0.15s;
  }
  .detail-close:hover { color: var(--cyan); }

  /* Big image area */
  .detail-img {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-height: 230px;
    background: linear-gradient(150deg, #090c14 0%, #10141e 100%);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    flex-shrink: 0;
  }

  .detail-frame {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    opacity: 0.85;
    filter: hue-rotate(10deg) saturate(0.8);
  }

  .detail-icon {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    padding: 30px;
  }

  .detail-unknown {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-size: 3rem;
    font-weight: 900;
    color: var(--border2);
  }

  /* Detail content */
  .detail-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    scrollbar-width: thin;
    scrollbar-color: var(--border2) transparent;
  }

  .detail-type {
    display: inline-block;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid currentColor;
    margin-bottom: 8px;
    opacity: 0.85;
  }

  .detail-name {
    font-family: 'Orbitron', monospace;
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.04em;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .dl {
    font-size: 0.55rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--text2);
    margin-bottom: 5px;
    display: block;
  }

  .detail-station {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: var(--cyan);
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }
  .detail-station::before { content: '⚙'; font-size: 0.75rem; }

  .detail-recipe {
    border: 1px solid var(--border);
    background: var(--panel2);
    margin-bottom: 20px;
  }

  .dr {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 10px;
    font-size: 0.7rem;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    letter-spacing: 0.03em;
  }
  .dr:last-child { border-bottom: none; }
  .dr::before { content: '·'; color: var(--cyan); flex-shrink: 0; font-size: 1rem; line-height: 0; }

  .detail-collect-btn {
    width: 100%;
    padding: 12px;
    font-family: 'Orbitron', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.15s;
    border: 1px solid var(--cyan);
    background: rgba(0,207,255,0.07);
    color: var(--cyan);
  }
  .detail-collect-btn:hover { background: rgba(0,207,255,0.18); }
  .detail-collect-btn.is-collected {
    border-color: var(--green);
    background: rgba(94,255,58,0.08);
    color: var(--green);
  }
  .detail-collect-btn.is-collected:hover { background: rgba(94,255,58,0.18); }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .sidebar  { display: none; }
    .detail   { width: 100%; }
    .bp-grid  { grid-template-columns: repeat(auto-fill, minmax(86px, 1fr)); }
  }
</style>
</head>
<body>

<!-- Top chrome bar -->
<div class="topbar">
  <a class="topbar-back" href="index.html">◂ &nbsp;Hub</a>
  <div class="topbar-crumb">
    <span class="crumb">ARC Raiders</span>
    <span class="crumb-sep">/</span>
    <span class="crumb active">Blueprints</span>
  </div>
  <div class="topbar-right">
    <div class="topbar-prog">
      <span>Collected &nbsp;<strong id="topProg">0 / 0</strong></span>
      <div class="tp-bar-bg"><div class="tp-bar-fill" id="topBar" style="width:0%"></div></div>
    </div>
  </div>
</div>

<div class="body-wrap">

  <!-- Sidebar -->
  <aside class="sidebar">

    <div class="sb-section">
      <div class="sb-heading">View</div>
      <button class="sb-btn active" data-filter="all">
        All <span class="sb-count" id="c-all">0</span>
      </button>
      <button class="sb-btn" data-filter="complete">
        Collected <span class="sb-count" id="c-complete">0</span>
      </button>
      <button class="sb-btn" data-filter="incomplete">
        Missing <span class="sb-count" id="c-incomplete">0</span>
      </button>
    </div>

    <div class="sb-divider"></div>

    <div class="sb-section">
      <div class="sb-heading">Type</div>
      <button class="sb-btn" data-filter="Weapon">
        <span class="dot" style="background:var(--orange)"></span>Weapon
        <span class="sb-count" id="c-Weapon">0</span>
      </button>
      <button class="sb-btn" data-filter="Mod">
        <span class="dot" style="background:var(--cyan)"></span>Mod
        <span class="sb-count" id="c-Mod">0</span>
      </button>
      <button class="sb-btn" data-filter="Grenade">
        <span class="dot" style="background:var(--gold)"></span>Grenade
        <span class="sb-count" id="c-Grenade">0</span>
      </button>
      <button class="sb-btn" data-filter="Mine">
        <span class="dot" style="background:var(--red)"></span>Mine
        <span class="sb-count" id="c-Mine">0</span>
      </button>
      <button class="sb-btn" data-filter="Augment">
        <span class="dot" style="background:var(--purple)"></span>Augment
        <span class="sb-count" id="c-Augment">0</span>
      </button>
      <button class="sb-btn" data-filter="Quick Use">
        <span class="dot" style="background:var(--green)"></span>Quick Use
        <span class="sb-count" id="c-Quick Use">0</span>
      </button>
      <button class="sb-btn" data-filter="Material">
        <span class="dot" style="background:var(--grey)"></span>Material
        <span class="sb-count" id="c-Material">0</span>
      </button>
    </div>

  </aside>

  <!-- Main -->
  <main class="main">

    <div class="filterbar">
      <div class="search-wrap">
        <span class="search-icon">⌕</span>
        <input class="searchbox" id="searchBox" type="text" placeholder="Search blueprints…">
      </div>
      <div class="result-count" id="resultCount">0 items</div>
    </div>

    <div class="grid-scroll">
      <div class="bp-grid" id="grid"></div>
    </div>

  </main>
</div>

<!-- Detail panel -->
<div class="backdrop" id="backdrop"></div>
<div class="detail"   id="detail">
  <div class="detail-head">
    <span class="detail-head-label">// Blueprint Details</span>
    <button class="detail-close" id="detailClose">✕</button>
  </div>
  <div class="detail-img" id="detailImg">
    <img class="detail-frame" id="detailFrame" src="" alt="">
    <img class="detail-icon"  id="detailIcon"  src="" alt="">
    <div class="detail-unknown" id="detailUnknown" style="display:none">?</div>
  </div>
  <div class="detail-body">
    <span class="detail-type" id="detailType"></span>
    <div class="detail-name"  id="detailName"></div>
    <span class="dl">// Crafting Station</span>
    <div class="detail-station" id="detailStation"></div>
    <span class="dl">// Required Materials</span>
    <div class="detail-recipe"  id="detailRecipe"></div>
    <button class="detail-collect-btn" id="collectBtn">Mark as Collected</button>
  </div>
</div>

<script>
// ── Image filenames (matching what the PowerShell script downloaded) ──
const IMG_DIR   = 'images/blueprints/';
const FRAME_SRC = IMG_DIR + 'UI_Blueprint_Background.webp';

