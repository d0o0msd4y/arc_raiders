const TYPE_COLOR = { Weapon:'#ff6b35', Grenade:'#ffcc44', Mine:'#ff3355', Augment:'#b06aff', Mod:'#00cfff', 'Quick Use':'#5eff3a', Material:'#556070', Ammo:'#556070', '???':'#2a3350' };
const TYPES = ['Weapon','Mod','Grenade','Mine','Augment','Quick Use','Material'];
const STORAGE_KEY = 'arc_blueprints_v3';

let state = {};
let currentFilter = 'all';
let searchQuery   = '';
let activeItem    = null;

function load() { try { const s = localStorage.getItem(STORAGE_KEY); if (s) state = JSON.parse(s); } catch(e){} }
function save() { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e){} }
function isCollected(name) { return !!state[name]; }
function setCollected(name, v) { state[name] = v; save(); }

function matchesBp(bp) {
  const f = currentFilter;
  if (f === 'complete')   { if (!isCollected(bp.name)) return false; }
  if (f === 'incomplete') { if (isCollected(bp.name))  return false; }
  if (TYPES.includes(f))  { if (bp.type !== f)          return false; }
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    if (!bp.name.toLowerCase().includes(q) && !bp.type.toLowerCase().includes(q)) return false;
  }
  return true;
}

function updateCounts() {
  const total = BLUEPRINTS.length;
  const done  = BLUEPRINTS.filter(b => isCollected(b.name)).length;
  document.getElementById('c-all').textContent      = total;
  document.getElementById('c-complete').textContent = done;
  document.getElementById('c-incomplete').textContent = total - done;
  TYPES.forEach(t => {
    const el = document.getElementById('c-' + t);
    if (el) el.textContent = BLUEPRINTS.filter(b => b.type === t).length;
  });
  document.getElementById('topProg').textContent = done + ' / ' + total;
  document.getElementById('topBar').style.width  = (total ? (done / total * 100).toFixed(1) : 0) + '%';
}

function render() {
  const grid    = document.getElementById('grid');
  const visible = BLUEPRINTS.filter(matchesBp);
  document.getElementById('resultCount').textContent = visible.length + (visible.length === 1 ? ' item' : ' items');
  grid.innerHTML = '';

  if (!visible.length) {
    grid.innerHTML = '<div class="no-results">// NO BLUEPRINTS MATCH //</div>';
    updateCounts();
    return;
  }

  visible.forEach(bp => {
    const isUnknown = bp.type === '???';
    const col = isCollected(bp.name);

    const card = document.createElement('div');
    card.className = 'bp-card' + (col ? ' collected' : '');
    card.dataset.type = bp.type;

    // Image area
    const imgDiv = document.createElement('div');
    imgDiv.className = 'bp-img';

    if (!isUnknown) {
      const frame = document.createElement('img');
      frame.className = 'bp-frame';
      frame.src = FRAME_SRC;
      frame.alt = '';
      imgDiv.appendChild(frame);

      if (IMG[bp.name]) {
        const icon = document.createElement('img');
        icon.className = 'bp-icon';
        icon.src = IMG_DIR + IMG[bp.name];
        icon.alt = bp.name;
        imgDiv.appendChild(icon);
      }

      const tick = document.createElement('div');
      tick.className = 'bp-tick';
      tick.textContent = '✓';
      imgDiv.appendChild(tick);
    } else {
      imgDiv.classList.add('no-frame');
      const unk = document.createElement('div');
      unk.className = 'bp-unknown';
      unk.textContent = '?';
      imgDiv.appendChild(unk);
    }

    // Label
    const label = document.createElement('div');
    label.className = 'bp-label';
    label.innerHTML = `<span class="bp-name">${bp.name}</span><span class="bp-type">${bp.type}</span>`;

    card.appendChild(imgDiv);
    card.appendChild(label);

    if (!isUnknown) {
      card.addEventListener('click', () => openDetail(bp));
    }

    grid.appendChild(card);
  });

  updateCounts();
}

// ── Detail panel ──
function openDetail(bp) {
  activeItem = bp;
  const col = isCollected(bp.name);

  // Image
  const hasImg = !!IMG[bp.name];
  document.getElementById('detailFrame').src     = FRAME_SRC;
  document.getElementById('detailFrame').style.display = hasImg ? '' : 'none';
  document.getElementById('detailIcon').src      = hasImg ? IMG_DIR + IMG[bp.name] : '';
  document.getElementById('detailIcon').style.display  = hasImg ? '' : 'none';
  document.getElementById('detailUnknown').style.display = hasImg ? 'none' : 'flex';

  // Text
  const typeEl = document.getElementById('detailType');
  typeEl.textContent   = bp.type;
  typeEl.style.color   = TYPE_COLOR[bp.type] || '#fff';
  typeEl.style.borderColor = TYPE_COLOR[bp.type] || '#fff';

  document.getElementById('detailName').textContent    = bp.name;
  document.getElementById('detailStation').textContent = bp.craftedAt;
  document.getElementById('detailRecipe').innerHTML    =
    bp.recipe.map(r => `<div class="dr">${r}</div>`).join('');

  refreshCollectBtn();

  document.getElementById('detail').classList.add('open');
  document.getElementById('backdrop').classList.add('open');
}

function refreshCollectBtn() {
  if (!activeItem) return;
  const col = isCollected(activeItem.name);
  const btn = document.getElementById('collectBtn');
  btn.textContent = col ? '✓  Collected' : 'Mark as Collected';
  btn.className   = 'detail-collect-btn' + (col ? ' is-collected' : '');
}

function closeDetail() {
  document.getElementById('detail').classList.remove('open');
  document.getElementById('backdrop').classList.remove('open');
}

// ── Events ──
document.getElementById('collectBtn').addEventListener('click', () => {
  if (!activeItem) return;
  setCollected(activeItem.name, !isCollected(activeItem.name));
  refreshCollectBtn();
  render();
});

document.getElementById('detailClose').addEventListener('click', closeDetail);
document.getElementById('backdrop').addEventListener('click', closeDetail);

document.querySelectorAll('.sb-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.sb-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = btn.dataset.filter;
    render();
  });
});

document.getElementById('searchBox').addEventListener('input', e => {
  searchQuery = e.target.value.trim();
  render();
});

// ── Init ──
load();
render();
</script>
</body>
</html>
